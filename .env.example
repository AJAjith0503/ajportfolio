# ==============================================================
# Environment Variables — copy this file to .env.local to run locally
# Add these same variables in your Vercel project dashboard:
# https://vercel.com/dashboard → Project → Settings → Environment Variables
# ==============================================================

# Resend API Key — used for the contact form email sending
# Get yours at: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here


